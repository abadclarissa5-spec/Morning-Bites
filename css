/* MENU TO NEW POP UP */
.modal {
  display: none;
  position: fixed;
  z-index: 999;
  left: 0;
  top: 0;
  width: 100%;
  height: 100%;
  background: rgba(0,0,0,0.7);
}



.modal-content img {
  width: 100%;
  border-radius: 10px;
}

.close {
  float: right;
  font-size: 25px;
  cursor: pointer;
}

.controls button {
  margin: 10px;
  padding: 8px 15px;
  cursor: pointer;
}


.modal-content img {
  cursor: pointer;
  transition: 0.3s;
}

.modal-content img:hover {
  transform: scale(1.02);
}


.menu-list {
 display: flex;
  flex-direction: column;
  gap: 12px;
  margin-top: 10px;
}

.menu-item {
  display: flex;
  align-items: center;
  gap: 15px;
  padding: 12px;
  border-radius: 12px;
  background: transparent; /* removes white box feel */
  transition: 0.3s;
}

/* pag clinick loob ng menu mag hhigligt */
.menu-item:hover {
 background: rgba(249, 249, 247, 0.107);
  transform: translateX(5px);
}

/* shadow sa mga pic ng menu inside */
.menu-item img {
   width: 75px;
  height: 75px;
  object-fit: cover;
  border-radius: 12px;
  box-shadow: 0 3px 10px rgba(0, 0, 0, 0.84);
}

/* title inside ng menu */
.menu-item .info h3 {
  margin: 0;
  font-size: 16px;
  font-weight: 600;
  color: #cecdcd;
  text-align: center;
}

/* font sa loob ng menu */
.menu-item .info p {
  margin: 2px 0;
  font-size: 11px;
  color: #fcfcfc;

}

/* loob ng menu */
.modal-content {
  background: #3b141c;
  width: 90%;
  max-width: 450px;
  margin: 8% auto;
  padding: 20px;
  border-radius: 15px;
  max-height: 80vh;
  overflow-y: auto;
}



/* img ng menu sa loob mas bigger + clearer image */
.menu-item img {
  width: 140px;
  height: 100px;
  object-fit: cover;
  border-radius: 15px;
}

/* text alignment sa loob ng menu */
.menu-item .info {
  display: flex;
  flex-direction: column;
  justify-content: center;
  align-items: center;
  text-align: center;
}

/* Bg sa loob ng menupag pinindot yung menu */
.modal {
  display: none;
  position: fixed;
  top: 0;
  left: 0;
  width: 100%;
  height: 100%;
  background: rgba(0,0,0,0.7);
}

/* THIS IS THE CLICK EFFECT */
.modal:target {
  display: block;
}

.modal-content {
  background: #3b141c;
  width: 90%;
  max-width: 450px;
  margin: 8% auto;
  padding: 20px;
  border-radius: 15px;
  color: white;
  position: relative;
}

/* Text sa loob ng MENU */
.close {
  position: absolute;
  right: 15px;
  top: 10px;
  font-size: 25px;
  color: white;
  text-decoration: none;
}

 /* remove underline */
.menu-card a {
  text-decoration: none;  
  color: inherit;         
}
 /* same color  */


/* para sure kahit visited or hover */
.menu-card a:visited,
.menu-card a:hover,
.menu-card a:active {
  color: inherit;
  text-decoration: none;
}

/* SENG BOUTTON pag clinick mag hhiglight */
#contact button:hover {
  background: #5a1f29;
}


/* add to cart */
.cart-btn {
  margin-top: 8px;
  padding: 8px 15px;
  border: none;
  border-radius: 20px;
  background: white;
  color: #3b141c;
  cursor: pointer;
  transition: 0.3s;
  font-weight: 600;
}

.cart-btn:hover {
  background: #d8c7ca;
  transform: scale(1.05);
}

/* butoon for see more */
.menu-btn {
  display: inline-flex;
  align-items: center;
  justify-content: center;

  padding: 6px 14px;
  background: #3b141ca2;
  color: white;

  border-radius: 20px;
  text-decoration: none;
  font-weight: 600;

  transition: 0.3s;

  width: fit-content;
  margin: 10px auto;
}

.menu-btn:hover {
  background: #41272c;
  transform: scale(1.05);
}

/* sa see more para pantay */
.menu-card {
  display: flex;
  flex-direction: column;
  justify-content: space-between;
  height: 100%;
}



